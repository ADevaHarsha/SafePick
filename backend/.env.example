# PostgreSQL connection (local or hosted)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/safepick

# API
PORT=4000

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=24h

# SMS_MOCK=true logs OTPs instead of sending (until Twilio is wired)
# SMS_MOCK=true

# Comma-separated origins for CORS, or leave unset to reflect request origin in dev
# CORS_ORIGIN=http://localhost:9002
